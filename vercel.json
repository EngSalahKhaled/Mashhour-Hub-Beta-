{
  "version": 2,
  "builds": [
    { "src": "api/src/server.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "admin-dashboard/dist/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/src/server.js" },
    { "source": "/admin", "destination": "/admin-dashboard/dist/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin-dashboard/dist/$1" }
  ]
}
