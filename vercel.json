{
  "version": 2,
  "builds": [
    {
      "src": "api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "admin-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist",
        "installCommand": "npm install --legacy-peer-deps"
      }
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/src/server.js" },
    { "source": "/assets/(.*)", "destination": "/admin-dashboard/assets/$1" },
    { "source": "/admin", "destination": "/admin-dashboard/index.html" },
    { "source": "/admin/(.*)", "destination": "/admin-dashboard/index.html" },
    { "source": "/(.*)", "destination": "/$1" }
  ]
}
