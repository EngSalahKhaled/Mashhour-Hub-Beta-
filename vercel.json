{
  "version": 2,
  "builds": [
    {
      "src": "api/src/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "admin-dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/src/server.js"
    },
    {
      "source": "/admin",
      "destination": "/admin-dashboard/dist/index.html"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/admin-dashboard/dist/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
