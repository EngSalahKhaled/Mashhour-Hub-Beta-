# ─────────────────────────────────────────────────────────────────────────────
# Mashhor Hub Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=5000

# ─── Firebase Service Account ─────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
# → Generate new private key (downloads a JSON file)
# Copy the values from that JSON file into the vars below.

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ⚠️  IMPORTANT: Paste the private key exactly as-is from the JSON file.
# It will contain literal \n characters — that is correct. Do NOT add quotes.
# In Vercel dashboard, paste the raw value (with the \n characters) directly.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n

# Firebase Storage bucket (format: your-project-id.firebasestorage.app)
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Leave empty to allow all origins (development only).
# Production: update to your actual domain(s)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,https://www.mashhor-hub.com,https://mashhor-hub.com,https://mashhour-hub-beta.vercel.app

# ─── SMTP Settings (Email Notifications) ──────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@mashhor-hub.com
SMTP_PASS=your_smtp_password_here

# ─── reCAPTCHA ─────────────────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Google Analytics GA4 ──────────────────────────────────────────────────────
# Property ID from Google Analytics (found under Admin → Property Settings)
GA4_PROPERTY_ID=0

# ─── ERP & Billing (MyFatoorah) ────────────────────────────────────────────────
# Use https://apitest.myfatoorah.com for testing, and https://api.myfatoorah.com for live
MYFATOORAH_BASE_URL=https://apitest.myfatoorah.com
MYFATOORAH_API_KEY=your_test_or_live_api_key_here
WEBHOOK_SECRET=your_webhook_secret_for_verifying_payments

# ─── Frontend URL ──────────────────────────────────────────────────────────────
FRONTEND_URL=https://mashhor-hub.com
