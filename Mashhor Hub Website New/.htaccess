# ================================================================
# Mohamed Reda Portfolio — Apache Config (Hardened Security)
# ================================================================

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "0"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
  Header set Content-Security-Policy "default-src 'self' https:; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://www.googletagmanager.com https://region1.google-analytics.com https://connect.facebook.net; frame-src 'self' https://www.youtube.com https://youtube.com https://www.google.com; media-src 'self' https:; form-action 'self' https://wa.me; upgrade-insecure-requests;"
  Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
  Header set X-Permitted-Cross-Domain-Policies "none"
  Header set X-Download-Options "noopen"
  Header set Origin-Agent-Cluster "?1"
  Header set Cross-Origin-Embedder-Policy "unsafe-none"
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header set Cross-Origin-Resource-Policy "same-origin"
  Header always unset Server
  Header always unset X-Powered-By
</IfModule>

# --- Default Page & Error Document ---
DirectoryIndex index.html
ErrorDocument 404 /404.html

# --- Brotli Compression (preferred) ---
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml
  AddOutputFilterByType BROTLI_COMPRESS text/css application/javascript application/json
  AddOutputFilterByType BROTLI_COMPRESS application/xml application/xhtml+xml
  AddOutputFilterByType BROTLI_COMPRESS image/svg+xml font/woff2
</IfModule>

# --- GZIP Compression (fallback) ---
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml
  AddOutputFilterByType DEFLATE text/css application/javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2
  # Compress all text/* types
  <IfModule mod_filter.c>
    AddOutputFilterByType DEFLATE text/*
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
  </IfModule>
</IfModule>

# --- Browser Caching ---
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType application/json "access plus 1 month"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# --- Cache-Control immutable for versioned assets ---
<IfModule mod_headers.c>
  # Long-lived immutable cache for CSS, JS, fonts, images
  <FilesMatch "\.(css|js|woff2|woff|ttf|otf|eot|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # Short cache for HTML
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
  <FilesMatch "^(thank-you|consultation-booked)\.html$">
    Header set X-Robots-Tag "noindex, nofollow, noarchive"
  </FilesMatch>
</IfModule>

# --- ETag optimization ---
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

# --- Force HTTPS ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# --- Prevent directory listing ---
Options -Indexes

# --- Block access to sensitive files (build scripts, source maps, configs) ---
<FilesMatch "\.(js\.map|ts|tsx|jsx|sh|ps1|json|lock|md|txt|xml)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

# Allow specific public files
<FilesMatch "^(manifest\.json|robots\.txt|sitemap\.xml|humans\.txt|llms\.txt|llms-full\.txt|security\.txt|sw\.js|feed\.xml)$">
  <IfModule mod_authz_core.c>
    Require all granted
  </IfModule>
</FilesMatch>

# --- Block access to build scripts, node_modules, src dir ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Block node_modules
  RewriteRule ^node_modules/ - [F,L]
  
  # Block src directory
  RewriteRule ^src/ - [F,L]
  
  # Block build/config files
  RewriteRule ^(build|copy-to-dist|check-|extract-|fix-|fix_|generate-|inject-|migrate|repair-|update-).*\.js$ - [F,L]
  RewriteRule ^package(-lock)?\.json$ - [F,L]
  RewriteRule ^\.claude/ - [F,L]
  RewriteRule ^\.agents?/ - [F,L]
  
  # Block dist.zip if uploaded
  RewriteRule ^dist\.zip$ - [F,L]
</IfModule>

# --- Block common attack vectors ---
<IfModule mod_rewrite.c>
  # Allow vault PHP files explicitly (password-protected prompt viewer)
  RewriteRule ^prompts/vault\.php$ - [L]
  RewriteRule ^prompts/vault-viewer\.php$ - [L]
  RewriteRule ^ar/prompts/vault\.php$ - [L]
  RewriteRule ^ar/prompts/vault-viewer\.php$ - [L]

  # Block all other PHP file access attempts
  RewriteRule \.php$ - [F,L]

  # Reject unsafe HTTP methods
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)$ [NC]
  RewriteRule .* - [F,L]
  
  # Allow .well-known for security.txt etc.
  RewriteRule ^\.well-known/ - [L]

  # Block hidden files (.env, .git, etc.)
  RewriteRule (^\.|/\.) - [F,L]

  # Block accidental backup and config leak extensions
  RewriteRule \.(bak|old|orig|save|swp|tmp|sql|ini|ya?ml|env)$ - [F,L,NC]
  
  # Block WordPress attack paths
  RewriteRule ^wp-(admin|login|includes|content) - [F,L]

  # Block common CMS/framework probe paths
  RewriteRule ^(administrator|joomla|drupal|magento|vendor|cgi-bin) - [F,L]

  # Block SQL injection attempts in query strings
  RewriteCond %{QUERY_STRING} (union|select|insert|drop|delete|update|concat|char\(|cast\(|benchmark|sleep\() [NC]
  RewriteRule .* - [F,L]

  # Block suspicious user agents (scanners/bots)
  RewriteCond %{HTTP_USER_AGENT} (nikto|sqlmap|nmap|masscan|dirbuster|gobuster|wpscan) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# --- Disable server signature ---
ServerSignature Off
