# ----------------------------------------------------------------------
# Mashhor Hub - Ultimate Hostinger Deployment Configuration
# ----------------------------------------------------------------------

# 0. Force UTF-8 Encoding
AddDefaultCharset UTF-8

# 1. Root & URL Rewrites
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1.1 Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 1.2 API Redirect (Ensure /api requests go to the Node.js process)
    # On Hostinger Node Selector, if you set App URL to /api, it usually handles this.
    # We add this to prevent index.html conflict.
    RewriteCond %{REQUEST_URI} ^/api [NC]
    RewriteRule .* - [L]

    # 1.3 Admin Dashboard SPA Routing
    # If using /admin for the React Dashboard
    RewriteCond %{REQUEST_URI} ^/admin [NC]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^admin/(.*)$ admin/index.html [L,QSA]

    # 1.4 Main Site Clean URLs
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} /(.*)/$
    RewriteRule ^ /%1 [R=301,L]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# 2. Performance & Security
Options -Indexes
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
</IfModule>
