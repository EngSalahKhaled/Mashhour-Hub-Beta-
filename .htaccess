# ----------------------------------------------------------------------
# Mashhor Hub - Ultimate Hostinger Server Configuration (Apache/LiteSpeed)
# ----------------------------------------------------------------------

# ======================================================================
# 0. FORCE UTF-8 ENCODING ON ALL TEXT FILES (CRITICAL)
# ======================================================================
# Method 1: Default charset for all text responses
AddDefaultCharset UTF-8

# Method 2: Per-extension charset declaration
AddCharset UTF-8 .html .htm .css .js .xml .json .svg .txt

# Method 3: Header-level override for JS/CSS/HTML (most reliable on LiteSpeed)
<IfModule mod_headers.c>
    <FilesMatch "\.(js)$">
        Header set Content-Type "application/javascript; charset=UTF-8"
    </FilesMatch>
    <FilesMatch "\.(css)$">
        Header set Content-Type "text/css; charset=UTF-8"
    </FilesMatch>
    <FilesMatch "\.(html|htm)$">
        Header set Content-Type "text/html; charset=UTF-8"
    </FilesMatch>
</IfModule>

# ======================================================================
# 1. ROOT AND URL REWRITES (Clean URLs & HTTPS)
# ======================================================================
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS to secure the connection immediately
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Redirect trailing slashes to remove them (SEO clean URLs)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} /(.*)/$
    RewriteRule ^ /%1 [R=301,L]

    # Hide .html extensions and force clean URLs
    # Example: /about.html becomes /about
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# ======================================================================
# 2. SECURITY HEADERS & DIRECTORY PROTECTION
# ======================================================================
# Prevent directory browsing (blocks others from seeing a list of your files)
Options -Indexes

<IfModule mod_headers.c>
    # Force browsers to always use HTTPS
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

    # Block Cross-Site Scripting (XSS)
    Header set X-XSS-Protection "1; mode=block"

    # Prevent Clickjacking
    Header set X-Frame-Options "SAMEORIGIN"

    # Prevent MIME-Sniffing (force browsers to obey Content-Type)
    Header set X-Content-Type-Options "nosniff"

    # Control Referrer information
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Hide PHP/Apache version headers for security
    Header unset X-Powered-By
    Header unset Server
</IfModule>

# Block access to hidden files and directories (e.g. .git, .env)
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block malicious bots & wp-admin vulnerability scanners
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/(wp-admin|wp-login.php|xmlrpc.php) [NC]
    RewriteRule .* - [F,L]
</IfModule>

# ======================================================================
# 3. PROFESSIONAL COMPRESSION (GZIP / DEFLATE)
# ======================================================================
# This compresses text, html, js, css, xml and makes them load 70% faster
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ======================================================================
# 4. BROWSER CACHING (EXPIRES)
# ======================================================================
# Instructs the browser to cache files locally instead of re-downloading
<IfModule mod_expires.c>
    ExpiresActive On

    # Images & Media: Cache for 1 Year
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    ExpiresByType video/webm "access plus 1 year"
    ExpiresByType application/pdf "access plus 1 year"

    # Fonts: Cache for 1 Year
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # Code Assets: Cache for 1 Month
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Default
    ExpiresDefault "access plus 2 days"
</IfModule>

# ======================================================================
# 5. ERROR HANDLING
# ======================================================================
ErrorDocument 404 /404.html
